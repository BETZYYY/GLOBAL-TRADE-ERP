# ─── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── MySQL Database ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=globaltrade_erp

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=8h

# ─── FX Rate Provider (OpenExchangeRates) ────────────────
OPEN_EXCHANGE_RATES_APP_ID=your_app_id_here
OPENEXCHANGERATES_KEY=your_app_id_here
OPEN_EXCHANGE_RATES_BASE_URL=https://openexchangerates.org/api

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
